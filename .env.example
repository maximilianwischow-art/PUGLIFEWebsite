WCL_CLIENT_ID=your_client_id_here
WCL_CLIENT_SECRET=your_client_secret_here
# Free WCL API keys have a low rate limit; the server spaces GraphQL calls and retries 429s.
# Raise interval if you still see "Too many requests" (Patreon increases the WCL cap).
WCL_MIN_INTERVAL_MS=350
WCL_MAX_RETRIES=8
# Extra WCL request per report (deaths, attendance, encounter heatmap, loot). Lower = fewer API calls.
WCL_PER_REPORT_DETAIL_CAP=18
# Attendance % and Events parse badge (best boss percentile per log, max across logs): how many latest qualifying raid logs count (25-player only — Kara & ZA excluded).
# WCL_ATTENDANCE_RECENT_RAIDS=6
# Test rankings + parse by character name (requires restart): GET /api/wcl/guild/<guildId>/debug-character-rankings?name=ExactLogName&reportCode=optional
# WCL_DEBUG_RANKINGS=1
# GraphQL "query complexity" cap on WCL (~50k). Lower = fewer field/fight cost; raise if you have a high WCL API tier.
WCL_MAX_GUILD_REPORTS_LIMIT=40
# Reuse one filtered guild report list across dashboard API routes (ms). Set 0 to disable TTL only (in-flight dedupe still helps).
WCL_GUILD_REPORTS_CACHE_MS=45000
# Split boss fight IDs across multiple requests (tables, rankings, loot events scale with fight count).
WCL_MAX_FIGHT_IDS_PER_QUERY=24
WCL_LOOT_EVENTS_LIMIT=1500
# Same calendar day + same instance: keep one log; prefer this uploader (WCL site name, comma order = priority).
WCL_PRIORITY_LOG_UPLOADERS=tibtoth
# IANA zone for "same day" dedupe (e.g. Europe/Berlin). Should match when your team schedules raids.
WCL_CALENDAR_TIMEZONE=Europe/Berlin
# Raid night / instance rules are fixed in server.js: Gruul+Mag Thu, Kara Sun.
# Character names that must appear in each log (ranked + combat roster). Leave empty to disable.
WCL_REQUIRED_RAID_PLAYERS=Gernig
PORT=8787
# --- HTTP hardening & perf (Express) ---
# NODE_ENV=production enables longer static cache + CSP upgrade-insecure-requests.
# Behind nginx/caddy: TRUST_PROXY=1 so rate limits & IPs are correct.
TRUST_PROXY=0
# TRUST_PROXY_HOPS=1
# Comma-separated browser origins for CORS, or * for reflect (dev). Omit for default open CORS.
# CORS_ORIGINS=https://your-domain.example
# Max /api requests per IP per rolling minute (dashboard does several calls on load).
API_RATE_LIMIT_PER_MIN=180
WCL_ALLOWED_GAME_ZONES=Karazhan,Gruul's Lair,Magtheridon's Lair,Serpentshrine Cavern,Tempest Keep,Hyjal Summit,Black Temple,Sunwell Plateau,Zul'Aman
RAID_HELPER_API_KEY=your_raid_helper_api_key_here
# Signup display `Main/Alt`: which segment is the WoW character name for Raider.io (default last = assigned toon after /).
# RAID_HELPER_SIGNUP_SLASH_CHARACTER=last
# RAID_HELPER_SIGNUP_SLASH_CHARACTER=first
RAID_HELPER_DEFAULT_EVENT_ID=your_event_id_here
# Same numeric ID as Discord: Server Settings → Widget → Server ID (optional if DISCORD_GUILD_ID is set — code falls back)
RAID_HELPER_SERVER_ID=your_discord_server_id_here
# Admin “heuristic merge” / WCL name reference: breadth (defaults use last 6 of each)
# RH_WCL_LINK_RAID_HELPER_EVENTS=6
# RH_WCL_LINK_WCL_REPORT_DETAILS=6
# Second-pass mapping for log names below main MIN_SCORE but ≥ this (default 62):
# RH_WCL_ORPHAN_MIN_SCORE=62
# Primary guild character roster on disk: data/rh-wcl-character-links.json (Raid Helper ↔ WCL). Public JSON: GET /api/wcl/guild/:guildId/characters
# --- Blizzard WoW Classic API (item icon + tooltip enrichment) ---
BLIZZARD_CLIENT_ID=your_blizzard_client_id_here
BLIZZARD_CLIENT_SECRET=your_blizzard_client_secret_here
# Region host for API calls: us, eu, kr, tw
BLIZZARD_REGION=eu
# Locale per region (example for EU):
BLIZZARD_LOCALE=en_GB
# TBC/Cata Classic progression namespace:
BLIZZARD_CLASSIC_NAMESPACE=static-classic-eu
# Item metadata cache TTL (ms):
ITEM_METADATA_CACHE_MS=86400000
# Optional: enrich full tooltip HTML from Wowhead power payload (1=enabled, 0=disabled):
WOWHEAD_TOOLTIP_ENABLED=1
# Wowhead game flavor path (tbc, classic, cata, etc):
WOWHEAD_GAME_FLAVOR=tbc
# Required when Raid Helper omits realm on signups: Rio + Battle.net character profile need a realm slug (e.g. thunderstrike).
# WOW_GUILD_REALM=thunderstrike
# WOW_PROFILE_REGION=eu
# WOW_EXTERNAL_SPEC_LOOKUP=1
# Pin one Classic flavor first (optional). Values like classicann-eu auto-expand to profile-classicann-eu.
# TBC Anniversary realms are also tried automatically after env (or first when unset): profile-classicann-{region}.
# BLIZZARD_PROFILE_NAMESPACE=classicann-eu
# Character profile GET (class + optional active spec) uses the same OAuth client as item/tooltips when enrichment runs.
# --- Discord OAuth (login for voting / admin) ---
DISCORD_CLIENT_ID=your_discord_oauth_client_id_here
DISCORD_CLIENT_SECRET=your_discord_oauth_client_secret_here
# Discord Server ID (same value as RAID_HELPER_SERVER_ID). Either variable satisfies Raid Helper API routes.
DISCORD_GUILD_ID=your_discord_server_id_here
# Public app URL used for OAuth callback defaults (must match Discord Developer Portal → OAuth2 → Redirects):
PUBLIC_BASE_URL=http://localhost:8787
# Optional explicit callback URL override:
# DISCORD_REDIRECT_URI=http://localhost:8787/auth/discord/callback
# If login fails after Discord with "invalid_grant", the redirect URL above usually does not match the Portal entry.
# Register both if you switch hosts: http://localhost:PORT/auth/discord/callback and http://127.0.0.1:PORT/auth/discord/callback
# Development only — bypass "must be in DISCORD_GUILD_ID" (never set in production):
# DISCORD_SKIP_GUILD_CHECK=1
# Discord Incoming Webhook URL for Admin → News Notifications and automated website news posts.
# Create it in Discord channel settings → Integrations → Webhooks. Keep it secret.
# DISCORD_NEWS_WEBHOOK_URL=https://discord.com/api/webhooks/...
# Optional for the Admin → News role dropdown and role pings. The webhook still sends the post;
# the bot token is only used to read guild roles from DISCORD_GUILD_ID / RAID_HELPER_SERVER_ID.
# DISCORD_BOT_TOKEN=your_discord_bot_token_here
# Minimum ms between persisted Discord member-count samples for Admin → Website Analytics (default 21600000 = 6h).
# DISCORD_MEMBER_SAMPLE_MIN_MS=21600000
# Optional: scan Discord profile/gear-check posts for Classic Armory links and queue admin-reviewed Account Assignment proposals.
# Requires DISCORD_BOT_TOKEN with Message Content intent and channel read/history access.
# DISCORD_PROFILE_INGEST_CHANNEL_ID=1479943093305217115
# DISCORD_PROFILE_INGEST_POLL_MS=120000
# DISCORD_PROFILE_INGEST_ENABLED=1
# Optional Admin -> Discord Role Sync uses the same DISCORD_BOT_TOKEN.
# Bot requirements: Manage Roles permission, and the bot role must be above DPS/Heal/Tank/PLB rank roles.
# Warcraft Logs guild ID used for "latest raid" MVP voting roster:
VOTING_GUILD_ID=817080
# Events roster: spec icons from WCL Damage Done (same GraphQL as the report UI). Uses latest tracked guild report; set 0 to disable.
EVENTS_WCL_SPEC_ICONS=1
# Optional: guild id for WCL icon lookup (defaults to VOTING_GUILD_ID).
# EVENTS_WCL_SPEC_ICON_GUILD_ID=
# Cache merged name→icon map (ms).
# WCL_ROSTER_ICON_CACHE_MS=900000
# P2 tracker editor restriction (Discord user IDs, comma-separated):
P2_EDITOR_DISCORD_IDS=308667806633951243
# Optional fallback by Discord display/usernames (comma-separated, case-insensitive):
P2_EDITOR_DISCORD_NAMES=highbullet
# Optional persistent data directory for vote/P2 JSON stores (important for hosts with ephemeral FS):
# On Render Starter+, mount a persistent disk (for example at /var/data) and set:
# DATA_DIR=/var/data
# If DATA_DIR is not set, server.js falls back to RENDER_DISK_MOUNT_PATH automatically on Render.
# DATA_DIR=/var/data
# Loot history cache TTL in milliseconds (serves stale data while refreshing in background):
LOOT_HISTORY_CACHE_MS=120000
# Session signing secret (required in production):
AUTH_SESSION_SECRET=replace_with_a_long_random_secret
