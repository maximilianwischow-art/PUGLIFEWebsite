{
  "name": "fallen-tacticians-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build:tailwind": "tailwindcss -i ./src/tailwind.css -o ./public/tailwind.css --minify",
    "watch:tailwind": "tailwindcss -i ./src/tailwind.css -o ./public/tailwind.css --watch",
    "validate": "node --check server.js && node scripts/audit-achievement-badges.mjs",
    "audit:badges": "node scripts/audit-achievement-badges.mjs",
    "repack:badges": "node scripts/repack-achievement-badges.mjs",
    "fix:badges": "npm run repack:badges && npm run audit:badges",
    "generate:responsive-assets": "node scripts/generate-responsive-assets.mjs",
    "fetch-spec-icons": "node scripts/fetch-tbc-spec-icons.mjs",
    "guess-rh-wcl": "node scripts/guess-rh-wcl-links.mjs",
    "import-live-db": "node scripts/import-live-db-snapshot.mjs",
    "test:kara-roster": "node scripts/test-future-events-kara.mjs http://localhost:8787",
    "test:parse-badges": "node scripts/simulate-parse-badges.mjs http://localhost:8787",
    "test:hof-aggregate": "node scripts/test-hall-of-fame-aggregate.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.4"
  }
}
